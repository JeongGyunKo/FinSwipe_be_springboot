# PostgreSQL (Supabase direct connection)
DB_URL=jdbc:postgresql://<host>:5432/postgres
DB_USERNAME=postgres
DB_PASSWORD=your-db-password

# Finlight News API
FINLIGHT_API_KEY=your-finlight-api-key

# GenAI Server
GENAI_URL=https://your-genai-server.example.com
GENAI_USER=your-genai-user
GENAI_PASSWORD=your-genai-password

# Admin API Key (최소 16자)
ADMIN_API_KEY=your-admin-api-key-min-16-chars

# CORS (쉼표 구분, 기본값 *)
# CORS_ORIGINS=https://app.example.com,https://www.example.com

# 로그 레벨 (DEBUG|INFO|WARNING|ERROR, 기본값 INFO)
# LOG_LEVEL=INFO
